# Anthropic API key — required for Claude decision engine
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Kraken API keys — only needed for LIVE trading
# Paper trading works without any keys
# Generate at: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Agent settings
MODE=paper          # "paper" or "live"
INTERVAL=30         # seconds between analyses
PAIR=DOG/USD
